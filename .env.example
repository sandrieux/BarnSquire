# Database
DATABASE_URL="postgresql://barnsquire:barnsquire@localhost:5432/barnsquire_dev"

# Postgres container credentials (prod compose only — must match DATABASE_URL).
# In prod, DATABASE_URL host should be the service name, e.g.
# postgresql://barnsquire:STRONGPASS@postgres:5432/barnsquire
POSTGRES_USER="barnsquire"
POSTGRES_PASSWORD="barnsquire"
POSTGRES_DB="barnsquire"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production-min-32-chars"

# S3-compatible storage (MinIO in dev, Cloudflare R2 / AWS S3 in prod)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minio"
STORAGE_SECRET_KEY="minio123"
STORAGE_BUCKET="barnsquire"
STORAGE_REGION="us-east-1"
STORAGE_PUBLIC_URL="http://localhost:9000/barnsquire"

# Shared secret guarding the mobile push-notification cron endpoint
# (POST /api/cron/notifications with `Authorization: Bearer $CRON_SECRET`).
CRON_SECRET="dev-cron-secret-change-in-production"

# --- Mobile app (apps/mobile) ---
# Base URL the phone app calls (the web/API deployment). Set per environment.
# Use a LAN IP for a physical device in dev, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL="http://localhost:3000"
# EAS project id (from `eas init`), used for Expo push tokens.
# EAS_PROJECT_ID=""
