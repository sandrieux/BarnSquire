generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth.js v5 compatible) ────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  passwordHash       String?
  mustChangePassword Boolean   @default(false)
  image              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  barnMemberships BarnMembership[]
  auditLogs       AuditLog[]
  taskCompletions TaskCompletion[]
  ledgerEntries   LedgerEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Barn & Roles ─────────────────────────────────────────────────────────────

enum BarnRole {
  GLOBAL_ADMIN
  BARN_MANAGER
  CARETAKER
}

model Barn {
  id        String   @id @default(cuid())
  name      String
  address   String?
  timezone  String   @default("America/New_York")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  BarnMembership[]
  buildings    Building[]
  pastures     Pasture[]
  arenas       Arena[]
  animals      Animal[]
  appointments Appointment[]
  scheduledEvents ScheduledEvent[]
  feedStocks   FeedStock[]
}

model BarnMembership {
  id        String   @id @default(cuid())
  userId    String
  barnId    String
  role      BarnRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  barn Barn @relation(fields: [barnId], references: [id], onDelete: Cascade)

  @@unique([userId, barnId])
}

// ─── Location Hierarchy ───────────────────────────────────────────────────────

model Building {
  id        String   @id @default(cuid())
  barnId    String
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barn   Barn    @relation(fields: [barnId], references: [id], onDelete: Cascade)
  stalls Stall[]
  arenas Arena[]
}

enum StallType {
  STANDARD
  QUARANTINE
}

model Stall {
  id          String    @id @default(cuid())
  buildingId  String
  name        String
  type        StallType @default(STANDARD)
  maxCapacity Int       @default(1)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  building          Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  homeAnimals       Animal[]       @relation("HomeStall")
  turnoutEventsFrom TurnoutEvent[] @relation("TurnoutFromStall")
  turnoutEventsTo   TurnoutEvent[] @relation("TurnoutToStall")
}

model Pasture {
  id          String   @id @default(cuid())
  barnId      String
  name        String
  maxCapacity Int      @default(10)
  acreage     Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  barn              Barn               @relation(fields: [barnId], references: [id], onDelete: Cascade)
  homeAnimals       Animal[]           @relation("HomePasture")
  turnoutEventsFrom TurnoutEvent[]     @relation("TurnoutFromPasture")
  turnoutEventsTo   TurnoutEvent[]     @relation("TurnoutToPasture")
  exerciseSchedules ExerciseSchedule[] @relation("ExercisePasture")
}

// ─── Animals ──────────────────────────────────────────────────────────────────

enum AnimalSize {
  MINI
  SMALL
  MEDIUM
  LARGE
  DRAFT
}

model Animal {
  id             String     @id @default(cuid())
  barnId         String
  name           String
  species        String     @default("horse")
  breed          String?
  size           AnimalSize @default(MEDIUM)
  birthDate      DateTime?
  color          String?
  markings       String?
  microchipId    String?
  registrationId String?
  notes          String?
  profilePhotoId String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  homeStallId   String?
  homePastureId String?

  barn            Barn              @relation(fields: [barnId], references: [id], onDelete: Cascade)
  homeStall       Stall?            @relation("HomeStall", fields: [homeStallId], references: [id])
  homePasture     Pasture?          @relation("HomePasture", fields: [homePastureId], references: [id])
  mediaFiles      MediaFile[]
  feedingSchedules FeedingSchedule[]
  appointments    Appointment[]
  turnoutEvents   TurnoutEvent[]
  exerciseSchedules ExerciseSchedule[]
  taskCompletions TaskCompletion[]
  ledgerEntries   LedgerEntry[]
}

model MediaFile {
  id         String   @id @default(cuid())
  animalId   String
  storageKey String
  mimeType   String
  sizeBytes  Int
  caption    String?
  takenAt    DateTime?
  createdAt  DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

// ─── Care Ledger ──────────────────────────────────────────────────────────────

enum LedgerCategory {
  FEEDING
  MEDICATION
  ACTIVITY
  OTHER
}

// Manual, dated ledger entries authored by users. The Today completion history
// (TaskCompletion) is merged with these at read time to form the full ledger.
model LedgerEntry {
  id              String         @id @default(cuid())
  animalId        String
  category        LedgerCategory
  title           String
  notes           String?
  occurredAt      DateTime       @db.Date
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  animal      Animal             @relation(fields: [animalId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation(fields: [createdByUserId], references: [id])
  attachments LedgerAttachment[]

  @@index([animalId, occurredAt])
}

model LedgerAttachment {
  id            String   @id @default(cuid())
  ledgerEntryId String
  storageKey    String
  fileName      String
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime @default(now())

  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
}

// ─── Feeding Schedules ────────────────────────────────────────────────────────

enum TimeSlot {
  MORNING
  LUNCH
  EVENING
  CUSTOM
}

model FeedingSchedule {
  id           String    @id @default(cuid())
  animalId     String
  feedType     String
  quantity     String
  unit         String?
  slot         TimeSlot
  customTime   String?
  instructions String?
  isMedication Boolean   @default(false)
  startDate    DateTime
  endDate      DateTime?
  repeatDays   Int[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  animal      Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  completions TaskCompletion[]
}

// On-hand inventory for a feed type (one row per barn + feedType). The balance
// is `servingsRemaining` as of `asOfDate`; the current balance and days-of-feed
// remaining are predicted forward from the feeding schedules' consumption rate.
model FeedStock {
  id                   String   @id @default(cuid())
  barnId               String
  feedType             String
  servingsRemaining    Float    @default(0)
  asOfDate             DateTime @default(now())
  thresholdDays        Int      @default(3)
  servingsPerContainer Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  barn Barn @relation(fields: [barnId], references: [id], onDelete: Cascade)

  @@unique([barnId, feedType])
}

// ─── Appointments ─────────────────────────────────────────────────────────────

enum AppointmentType {
  VET
  FARRIER
  DENTAL
  CHIRO
  GROOMING
  OTHER
}

model Appointment {
  id           String          @id @default(cuid())
  barnId       String
  animalId     String
  type         AppointmentType
  title        String
  description  String?
  scheduledAt  DateTime
  durationMins Int?
  providerName String?
  cost         Decimal?        @db.Decimal(10, 2)
  notes        String?
  isCompleted  Boolean         @default(false)
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  barn        Barn                  @relation(fields: [barnId], references: [id], onDelete: Cascade)
  animal      Animal                @relation(fields: [animalId], references: [id], onDelete: Cascade)
  reminders   AppointmentReminder[]
  completions TaskCompletion[]
}

model AppointmentReminder {
  id             String          @id @default(cuid())
  appointmentId  String?
  animalId       String?
  barnId         String?
  type           AppointmentType
  title          String
  repeatWeeks    Int
  lastRemindedAt DateTime?
  nextRemindAt   DateTime
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

// ─── Turnout Scheduling ───────────────────────────────────────────────────────

model TurnoutEvent {
  id            String   @id @default(cuid())
  animalId      String
  fromStallId   String?
  fromPastureId String?
  toStallId     String?
  toPastureId   String?
  startTime     String   // time of day, "HH:MM"
  endTime       String   // time of day, "HH:MM"
  repeatDays    Int[]    // ISO weekdays this window applies to (1=Mon..7=Sun)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  animal      Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  fromStall   Stall?           @relation("TurnoutFromStall", fields: [fromStallId], references: [id])
  toStall     Stall?           @relation("TurnoutToStall", fields: [toStallId], references: [id])
  fromPasture Pasture?         @relation("TurnoutFromPasture", fields: [fromPastureId], references: [id])
  toPasture   Pasture?         @relation("TurnoutToPasture", fields: [toPastureId], references: [id])
  completions TaskCompletion[]
}

// ─── Exercise Scheduling ──────────────────────────────────────────────────────

enum ExerciseType {
  RIDING
  LUNGEING
  GROUNDWORK
  TURNOUT_EXERCISE
  HAND_WALKING
  TREADMILL
  SWIMMING
  OTHER
}

model ExerciseSchedule {
  id                String       @id @default(cuid())
  animalId          String
  type              ExerciseType
  trainer           String?
  locationArenaId   String?
  locationPastureId String?
  startTime         String       // time of day, "HH:MM"
  endTime           String?      // optional end time, "HH:MM"
  repeatDays        Int[]        // ISO weekdays this applies to (1=Mon..7=Sun)
  notes             String?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  animal          Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  locationArena   Arena?           @relation(fields: [locationArenaId], references: [id])
  locationPasture Pasture?         @relation("ExercisePasture", fields: [locationPastureId], references: [id])
  completions     TaskCompletion[]
}

// An exercise/work area; may sit inside a building or stand alone in the barn.
model Arena {
  id         String   @id @default(cuid())
  barnId     String
  buildingId String?
  name       String
  surface    String?  // e.g. "Sand", "Grass", "Rubber"
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  barn      Barn               @relation(fields: [barnId], references: [id], onDelete: Cascade)
  building  Building?          @relation(fields: [buildingId], references: [id])
  exercises ExerciseSchedule[]
}

// ─── Daily Task Tracking ──────────────────────────────────────────────────────

enum TaskType {
  FEEDING
  MEDICATION
  APPOINTMENT
  TURNOUT
  EXERCISE
  SCHEDULED_EVENT
}

// A recurring barn-level chore not tied to any animal (e.g. "Stall cleaning").
// Time-of-day window + ISO weekday repeats, mirroring ExerciseSchedule.
model ScheduledEvent {
  id         String   @id @default(cuid())
  barnId     String
  title      String
  startTime  String   // time of day, "HH:MM"
  endTime    String?  // optional end time, "HH:MM"
  repeatDays Int[]    // ISO weekdays this applies to (1=Mon..7=Sun)
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  barn        Barn             @relation(fields: [barnId], references: [id], onDelete: Cascade)
  completions TaskCompletion[]

  @@index([barnId])
}

model TaskCompletion {
  id                String    @id @default(cuid())
  taskType          TaskType
  scheduledDate     DateTime  @db.Date
  completedAt       DateTime?
  completedByUserId String?
  notes             String?
  skipped           Boolean   @default(false)
  skipReason        String?
  createdAt         DateTime  @default(now())

  feedingScheduleId String?
  appointmentId     String?
  turnoutEventId    String?
  exerciseScheduleId String?
  scheduledEventId  String?
  animalId          String?

  feedingSchedule  FeedingSchedule?  @relation(fields: [feedingScheduleId], references: [id])
  appointment      Appointment?      @relation(fields: [appointmentId], references: [id])
  turnoutEvent     TurnoutEvent?     @relation(fields: [turnoutEventId], references: [id])
  exerciseSchedule ExerciseSchedule? @relation(fields: [exerciseScheduleId], references: [id])
  scheduledEvent   ScheduledEvent?   @relation(fields: [scheduledEventId], references: [id])
  animal           Animal?           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  completedBy      User?             @relation(fields: [completedByUserId], references: [id])

  @@unique([feedingScheduleId, scheduledDate])
  @@unique([appointmentId, scheduledDate])
  @@unique([turnoutEventId, scheduledDate])
  @@unique([exerciseScheduleId, scheduledDate])
  @@unique([scheduledEventId, scheduledDate])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  barnId     String?
  action     String
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
