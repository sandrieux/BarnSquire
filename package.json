{
  "name": "barnsquire",
  "private": true,
  "license": "Elastic-2.0",
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @barnsquire/db db:push",
    "db:migrate": "pnpm --filter @barnsquire/db db:migrate",
    "db:studio": "pnpm --filter @barnsquire/db db:studio",
    "db:generate": "pnpm --filter @barnsquire/db db:generate",
    "db:seed": "pnpm --filter @barnsquire/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma", "sharp", "unrs-resolver"],
    "comment": "Dedupe @types/react (types only) so web's tsc doesn't see two copies. Do NOT override runtime react/react-dom — mobile must keep 19.0.0 to match react-native-renderer.",
    "overrides": {
      "@types/react": "^19.1.6"
    }
  }
}
