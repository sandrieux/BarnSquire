{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "device": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://barnsquire.lysranch.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "image": "latest" },
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://barnsquire.lysranch.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "6793155032" }
    }
  }
}
